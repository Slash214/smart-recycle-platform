    "/orders": {
      "get": {
        "summary": "订单列表（管理端/小程序）",
        "tags": [
          "order"
        ],
        "parameters": [
          {
            "schema": {
              "type": "integer",
              "default": 1
            },
            "in": "query",
            "name": "page",
            "required": false
          },
          {
            "schema": {
              "type": "integer",
              "default": 20
            },
            "in": "query",
            "name": "pageSize",
            "required": false
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "userid",
            "required": false
          },
          {
            "schema": {
              "type": "integer"
            },
            "in": "query",
            "name": "type",
            "required": false,
            "description": "1上门 2邮寄"
          },
          {
            "schema": {
              "type": "integer"
            },
            "in": "query",
            "name": "way",
            "required": false,
            "description": "收货方式"
          },
          {
            "schema": {
              "type": "integer"
            },
            "in": "query",
            "name": "status",
            "required": false,
            "description": "1待确认 2进行中 3已完成"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "keyword",
            "required": false,
            "description": "手机号/单号/快递公司/备注 关键词"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "startAt",
            "required": false,
            "description": "创建时间开始（ISO）"
          },
          {
            "schema": {
              "type": "string"
            },
            "in": "query",
            "name": "endAt",
            "required": false,
            "description": "创建时间结束（ISO）"
          }
        ],
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      },
      "post": {
        "summary": "创建订单",
        "tags": [
          "order"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "nums",
                  "phone"
                ],
                "properties": {
                  "nums": {
                    "type": "integer",
                    "minimum": 1
                  },
                  "price": {
                    "type": "string"
                  },
                  "phone": {
                    "type": "string"
                  },
                  "remark": {
                    "type": "string"
                  },
                  "way": {
                    "type": "integer",
                    "description": "1上门 2邮寄"
                  },
                  "userid": {
                    "type": "string",
                    "description": "管理员代下单可传；小程序端自动取token"
                  },
                  "type": {
                    "type": "integer",
                    "description": "1上门 2邮寄"
                  },
                  "visit_time": {
                    "type": "string"
                  },
                  "tracking_number": {
                    "type": "string"
                  },
                  "express_company": {
                    "type": "string",
                    "description": "快递公司名称（字符串）"
                  },
                  "areas": {
                    "type": "string"
                  },
                  "hourse_number": {
                    "type": "string"
                  },
                  "status": {
                    "type": "integer",
                    "description": "1待确认 2进行中 3已完成；默认1"
                  },
                  "remark_images": {
                    "oneOf": [
                      {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      },
                      {
                        "type": "string"
                      }
                    ],
                    "description": "备注图片URL数组"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
