{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^wd-(.*)": "wot-design-uni/components/wd-$1/wd-$1.vue"
		}
	},
	"pages": [
		{
			"path": "pages/index/index",
			"style": {
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/my/my",
			"style": {
				"navigationStyle": "custom"
			}
		},
		{
			"path": "pages/order-page/order-page",
			"style": {
				"navigationBarTitleText": "回收下单"
			}
		},
		{
			"path": "pages/order-list/order-list",
			"style": {
				"navigationBarTitleText": "订单列表",
				"navigationBarBackgroundColor": "#eef2ff",
				"navigationBarTextStyle": "black"
			}
		},
		{
			"path": "pages/order-detail/order-detail",
			"style": {
				"navigationBarTitleText": "订单详情",
				"navigationBarBackgroundColor": "#eef2ff",
				"navigationBarTextStyle": "black"
			}
		},
		{
			"path": "pages/details/details",
			"style": {
				"navigationBarTitleText": "报价"
			}
		},
		{
			"path": "pages/tips/tips",
			"style": {
				"navigationBarTitleText": "发货需知"
			}
		},
		{
			"path": "pages/setting/setting",
			"style": {
				"navigationBarTitleText": "设置"
			}
		},
		{
			"path": "pages/policy/policy",
			"style": {
				"navigationBarTitleText": "用户协议"
			}
		}
	],
	"globalStyle": {
		"navigationBarTextStyle": "black",
		"navigationBarTitleText": "数码网",
		"navigationBarBackgroundColor": "#F8F8F8",
		"backgroundColor": "#F8F8F8"
	}
}