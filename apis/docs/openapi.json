  "paths": {
    "/auth/login": {
      "post": {
        "summary": "登录并签发 JWT",
        "tags": [
          "auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "openid"
                ],
                "properties": {
                  "openid": {
                    "type": "string"
                  },
                  "platform": {
                    "type": "string",
                    "default": "WECHAT"
                  },
                  "userName": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Default Response"
          }
        }
      }
    },
    "/auth/admin/login": {
      "post": {
        "summary": "管理员登录并签发 JWT",
        "tags": [
          "auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "username",
                  "password"
                ],
                "properties": {
                  "username": {
                    "type": "string"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
